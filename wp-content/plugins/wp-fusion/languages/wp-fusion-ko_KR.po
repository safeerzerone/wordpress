#. Translators: %s is the name of the CRM.
#, php-format
msgid ""
"You'll be taken to %s to authorize WP Fusion and generate access keys for "
"this site."
msgstr "당신은 %s로 이동하여 WP Fusion을 인증하고 이 사이트에 대한 액세스 키를 생성하게 됩니다."

#: includes/admin/class-settings.php:2519
#: includes/crms/salesforce/admin/class-admin.php:78
