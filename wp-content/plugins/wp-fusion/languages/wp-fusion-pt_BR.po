msgstr "Não Conectado"

#: includes/admin/class-settings.php:2574
#: includes/crms/dynamics-365/class-dynamics-365-admin.php:241
#: includes/crms/highlevel/admin/class-admin.php:248
#: includes/crms/mautic/admin/class-admin.php:213
