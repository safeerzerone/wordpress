msgstr "Родительский заказ:"

#: includes/integrations/class-woo-subscriptions.php:1252
#: includes/integrations/class-woo-subscriptions.php:1279
#, php-format
msgid "Successfully synced to %s."
msgstr "Успешно синхронизировано с %s."

#: includes/integrations/class-woo-subscriptions.php:1254
#: includes/integrations/class-woo-subscriptions.php:1281
#, php-format
