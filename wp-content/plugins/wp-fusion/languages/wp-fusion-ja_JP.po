#: includes/admin/class-user-profile.php:60
msgid "Pull user meta"
msgstr "ユーザーメタをプル"

#: includes/admin/class-batch.php:151
#, php-format
msgid ""
"All WordPress users with a contact record will have their meta data loaded "
